# If Paynow checkout shows "Failed to fetch" while developing: `.env.local` overrides this file.
# Remove REACT_APP_SHOP_PAYNOW_LOCAL_URL from `.env.local` if it still says http://localhost:4000
# and you want to use the Railway URL from `.env.development` instead.

# --- Supabase (required for shop orders + delivery settings) ---
REACT_APP_SUPABASE_URL=https://iaorixerxnqedwgkqxtz.supabase.co
REACT_APP_SUPABASE_ANON_KEY=

# --- Shop Paynow (Node API in /server — CRA does not use Supabase Edge paynow-initiate) ---
# Production / shared API (Railway):
REACT_APP_SHOP_PAYNOW_LOCAL_URL=https://bykea-production.up.railway.app
# Local Paynow server only: REACT_APP_SHOP_PAYNOW_LOCAL_URL=http://localhost:4000
# Optional UI label for that gateway (default Paynow), e.g. Blue
# REACT_APP_PAYMENT_GATEWAY_DISPLAY_NAME=Blue

# --- Optional: Paynow result URL on Supabase (Paynow server callbacks after payment) ---
# Set secret PAYNOW_RESULT_URL on Supabase to your deployed paynow-result function if you use it:
#   https://iaorixerxnqedwgkqxtz.supabase.co/functions/v1/paynow-result

# --- Stripe card payments (browser publishable key only; secret key = Supabase secret STRIPE_SECRET_KEY) ---
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Deploy: supabase functions deploy stripe-payment --no-verify-jwt

# --- Google Maps (see root .env.example for API enablement) ---
REACT_APP_GOOGLE_MAPS_API_KEY=
# Optional: home map uses iframe embed only (no Maps JS). Omit for default: Maps JS + Google’s pin when key is set.
# REACT_APP_HOME_USE_MAPS_EMBED_ONLY=true

# --- Customer email verification (Resend; Edge function `customer-email-verify`) ---
# Set these as Supabase secrets (Dashboard → Edge Functions → Secrets), not in React:
#   RESEND_API_KEY=re_...
#   EMAIL_VERIFY_HMAC_SECRET=<long random string>
# Optional:
#   RESEND_FROM_EMAIL=InGo <admin@ingo.co.zw>
# Deploy: supabase functions deploy customer-email-verify --no-verify-jwt
# SQL: run supabase/app_users_email_verification.sql once (marks existing accounts verified)

# --- Password reset (same Resend + HMAC; Edge function `password-reset`) ---
# Uses EMAIL_VERIFY_HMAC_SECRET (or set PASSWORD_RESET_HMAC_SECRET separately on the function).
# Deploy: supabase functions deploy password-reset --no-verify-jwt
# SQL: run supabase/password_reset_support.sql once on the database

# --- Shop order placed (Resend; Edge `shop-order-placed-notify`) ---
# Emails the customer (if they entered an email) and each shop owner when a shop checkout is saved.
# Same RESEND_API_KEY / RESEND_FROM_EMAIL as above.
# Deploy: supabase functions deploy shop-order-placed-notify --no-verify-jwt
