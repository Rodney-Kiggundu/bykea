# Loaded automatically for `npm run build` (production). Do not put secrets here.
# Paynow initiation hits your Railway Node API (repo `server/`), not localhost.
# To use a different URL, change this file or set REACT_APP_SHOP_PAYNOW_LOCAL_URL in your host’s build env (Firebase, Netlify, etc.).
REACT_APP_SHOP_PAYNOW_LOCAL_URL=https://bykea-production.up.railway.app
