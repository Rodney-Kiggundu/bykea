# Listen port (Railway sets PORT automatically — omit PORT on Railway)
PORT=4000

# Paynow (from Paynow dashboard email) — required on Railway
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=

# Optional overrides (sensible defaults are baked in for this repo’s Railway + Firebase hosting):
# - PAYNOW_RESULT_URL defaults to https://bykea-production.up.railway.app/paynow/result
# - PAYNOW_RETURN_URL defaults to https://hotel-demo-11dcb.web.app/order-confirmation
# Set CUSTOMER_APP_PUBLIC_URL=https://YOUR-SITE.web.app if your Firebase project differs.
# PUBLIC_PAYNOW_API_ORIGIN=https://bykea-production.up.railway.app  (only if your API host changes)

# Customer return page after payment (your live app). Default: Firebase default project + /order-confirmation
PAYNOW_RETURN_URL=

# Server callback URL Paynow POSTs to. Default: this API’s /paynow/result on Railway
PAYNOW_RESULT_URL=

# Paynow test mode: shopper email cannot be arbitrary — use merchant registered email OR omit.
# Easiest fix for test integrations:
PAYNOW_OMIT_AUTH_EMAIL=true
# Optional: paste full merchant email Paynow shows in dashboard instead of masking (then you can omit the line above or set false)
# PAYNOW_MERCHANT_AUTH_EMAIL=it@example.co.zw

# Optional: update shop_customer_orders like the Edge Function does
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Relay for Supabase Edge (when Paynow resets TLS from Edge) ---
# Generate a long random string; use the SAME value in Supabase: supabase secrets set PAYNOW_RELAY_SECRET=...
PAYNOW_RELAY_SECRET=
# Optional override if Paynow changes path (default: https://www.paynow.co.zw/interface/initiatetransaction)
# PAYNOW_OFFICIAL_INITIATE_URL=
# On Supabase also set (public HTTPS to this server):
#   supabase secrets set PAYNOW_INITIATE_URL=https://YOUR_HOST/paynow/relay-initiate
#
# --- Railway.app ---
# Repo: push to GitHub → Railway "Deploy from GitHub" → Root Directory = `server`
# Frontend (CRA): defaults to Railway if unset — override if needed:
# REACT_APP_SHOP_PAYNOW_LOCAL_URL=https://bykea-production.up.railway.app
# See server/README.md → "Deploy on Railway"
