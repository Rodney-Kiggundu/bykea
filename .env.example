# Copy to `.env.local` and fill in. Never commit `.env.local`.
#
# --- Google Maps (route preview uses Maps Embed API) ---
# 1. Google Cloud Console → APIs & Services → ENABLE "Maps Embed API"
#    https://console.cloud.google.com/apis/library/maps-embed-backend.googleapis.com
# 1b. Customer home uses **Maps JavaScript API** when `REACT_APP_GOOGLE_MAPS_API_KEY` is set (live map + Google’s default pin). If JS is blocked (ApiTargetBlocked), add HTTP referrers for your origins or set REACT_APP_HOME_USE_MAPS_EMBED_ONLY=true to use Maps Embed only. Enable Maps JavaScript API:
#    https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
# 1c. Address suggestions (/request-delivery, /book-ride) use Places Autocomplete — enable:
#    https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# 1d. Route map geocoding (typed addresses → lat/lng) uses Geocoding API — enable:
#    https://console.cloud.google.com/apis/library/geocoding-backend.googleapis.com
# 2. Billing must be enabled on the project (Embed API usage is billable).
# 3. Credentials → your browser key → Application restrictions:
#    "HTTP referrers" → add http://localhost:3000/* (and your production URL/*).
# 4. API restrictions: restrict key to "Maps Embed API" + "Maps JavaScript API" + "Places API" + "Geocoding API" (or unrestricted for dev).
# 5. Typed-address search + autocomplete call Google via Supabase Edge (browser-safe). Deploy both functions, e.g.:
#      supabase functions deploy places-autocomplete
#      supabase functions deploy places-geocode
#    and set secret: supabase secrets set GOOGLE_MAPS_API_KEY=<same key or a server key with Places+Geocoding>
# You do NOT need "Directions API" for the iframe embed directions mode.
# Optional: bias address autocomplete to one country (ISO 3166-1 alpha-2), e.g. gb for UK
REACT_APP_ADDRESS_AUTOCOMPLETE_COUNTRY=
# Optional: Places Autocomplete language (default en)
REACT_APP_GOOGLE_PLACES_LANGUAGE=en
# Geo debug overlay on customer home + delivery/taxi map (also: ?debug_geo=1 or localStorage ingo_debug_geo=1)
REACT_APP_DEBUG_GEO=
REACT_APP_GOOGLE_MAPS_API_KEY=
# true = skip Maps JavaScript API on home; use Maps Embed iframe only (no default JS pin).
REACT_APP_HOME_USE_MAPS_EMBED_ONLY=
REACT_APP_SUPABASE_URL=https://iaorixerxnqedwgkqxtz.supabase.co
REACT_APP_SUPABASE_ANON_KEY=

# Optional: label shown in the app for card / redirect checkout (still uses Paynow API). Example: Blue
REACT_APP_PAYMENT_GATEWAY_DISPLAY_NAME=

# --- Shop checkout Paynow (local API in /server — CRA does not call Supabase Edge paynow-initiate) ---
# e.g. http://localhost:4000 — see server/.env and `npm run paynow:server`
REACT_APP_SHOP_PAYNOW_LOCAL_URL=

# --- Supabase Edge secrets (Paynow live / test) — set in Dashboard or CLI, not in CRA .env ---
# supabase secrets set PAYNOW_INTEGRATION_ID=your_id
# supabase secrets set PAYNOW_INTEGRATION_KEY=your_key
# supabase secrets set PAYNOW_RETURN_URL=https://your-domain.com/order-confirmation
# supabase secrets set PAYNOW_RESULT_URL=https://iaorixerxnqedwgkqxtz.supabase.co/functions/v1/paynow-result
# Edge URLs (reference): paynow-result for Paynow callbacks (initiate is local Node in this app setup)
# supabase secrets set PAYNOW_OMIT_AUTH_EMAIL=true
#   OR: supabase secrets set PAYNOW_MERCHANT_AUTH_EMAIL=merchant@email.com
# supabase secrets set PAYNOW_INITIATE_URL=https://your-host.example/paynow/relay-initiate
# supabase secrets set PAYNOW_RELAY_SECRET=long-random-string   (same as PAYNOW_RELAY_SECRET on relay server)
#   (optional — if Edge gets "Connection reset" to paynow.co.zw, use server/paynow relay or your own forwarder)

# --- Firebase (optional overrides; defaults match hotel-demo-11dcb) ---
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
